# ── Security ────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-here

# ── Database ─────────────────────────────────────────────
# Default is SQLite. To use a different DB in production (like PostgreSQL), 
# uncomment and update the line below:
# DATABASE_URL=sqlite:///delcon_leads.db

# ── Email Settings (Flask-Mailman) ───────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# Recipient for lead notifications
CONTACT_EMAIL=jroets@cyber.com

# ── Admin bootstrap ──────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
